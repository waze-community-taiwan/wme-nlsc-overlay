{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["wme-sdk-typings"],
    "lib": ["ES2020", "DOM"],
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*", "tests/**/*"]
}
